<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:Tutorials.ViewModels"
             xmlns:views="clr-namespace:Tutorials.Pages"
             x:Class="Tutorials.Pages.MainPage"
             x:DataType="viewmodel:MainViewModel"
             >

    <VerticalStackLayout Margin="20" Spacing="10">

        <ContentView Padding="20">
            <TableView Intent="Menu">
            <TableRoot>
                <TableSection Title="Menu">

                    <TextCell Text="Composants .NET MAUI"
                         Detail="Liste des contrôles .NET MAUI"
                         Command="{Binding NavigateCommand}"
                         CommandParameter="{x:Type views:GalleryPage}" />

                    <TextCell Text="Graphe"
                         Detail="Utilisation des graphes DevExpress.Maui.Charts"
                         Command="{Binding NavigateCommand}"
                         CommandParameter="{x:Type views:DevExpressChartPage}" />
                    
                    <TextCell Text="FirstMAUI"
                         Detail="Liste tata toto"
                         Command="{Binding NavigateCommand}"
                         CommandParameter="{x:Type views:FirstMauiPage}" />

                    <TextCell Text="Pays"
                         Detail="Liste des pays - https://data.enseignementsup-recherche.gouv.fr/explore/dataset/curiexplore-pay"
                         Command="{Binding NavigateCommand}"
                         CommandParameter="{x:Type views:CountryPage}" />

                    <TextCell Text="Unicodes"
                         Detail="Liste des unicodes"
                         Command="{Binding NavigateCommand}"
                         CommandParameter="{x:Type views:UnicodePage}" />

                    <TextCell Text="Culture"
                         Detail="Cultures Types"
                         Command="{Binding NavigateCommand}"
                         CommandParameter="{x:Type views:CultureInfoPage}" />

                    <TextCell Text="Nombre premiers"
                         Detail="Liste des nombres premiers"
                         Command="{Binding NavigateCommand}"
                         CommandParameter="{x:Type views:PrimeNumberPage}" />

                    <TextCell Text="Couleurs"
                         Detail="Définition des couleurs NETMAUI"
                         Command="{Binding NavigateCommand}"
                         CommandParameter="{x:Type views:ColorsPage}" />

                    <TextCell Text="Animations"
                         Detail="Différentes animations"
                         Command="{Binding NavigateCommand}"
                         CommandParameter="{x:Type views:Animations.AnimationsPage}" />
                </TableSection>
            </TableRoot>
        </TableView>
        </ContentView>
        <ImageButton Source="g7.png">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal">
                        <VisualState.Setters>
                            <Setter Property="Scale"
                                 Value="1" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="Scale"
                                 Value="0.8" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="PointerOver" />
                </VisualStateGroup>
            </VisualStateGroupList>
        </VisualStateManager.VisualStateGroups>
    </ImageButton>
    </VerticalStackLayout>
</ContentPage>
